  <diagram id="precedencia-expressoes" name="3. Hierarquia de precedência (Parser)">
    <mxGraphModel dx="1000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t3" value="Hierarquia de precedência das expressões (Parser)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="140" y="0" width="560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub3" value="Cada método chama o nível seguinte e, num laço, consome o(s) operador(es) do seu próprio nível — eliminando a recursividade à esquerda" style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="120" y="30" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="lbltop" value="menor precedência" style="text;html=1;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="700" y="60" width="140" height="24" as="geometry" />
        </mxCell>
        <mxCell id="lblbottom" value="maior precedência" style="text;html=1;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="700" y="892" width="140" height="24" as="geometry" />
        </mxCell>
        <mxCell id="arrowSide" value="" style="shape=flexArrow;endArrow=classic;html=1;fillColor=#f5f5f5;strokeColor=#999999;startSize=6;endSize=6;width=8;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="770" y="90" as="sourcePoint" />
            <mxPoint x="770" y="880" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="p1" value="parseExpression()&#10;(ponto de entrada)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="60" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="parseAssignment()  —  =, +=, -=, *=, /=, %=, &amp;=, |=, ^=, &lt;&lt;=, &gt;&gt;=, &gt;&gt;&gt;=" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="114" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="parseConditional()  —  ?  :" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="168" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="parseOr()  —  ||" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="222" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="parseAnd()  —  &amp;&amp;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="276" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p6" value="parseBitOr()  —  |" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="330" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p7" value="parseXor()  —  ^" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="384" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p8" value="parseBitAnd()  —  &amp;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="438" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p9" value="parseEquality()  —  ==, !=" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="492" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p10" value="parseRelational()  —  &lt;, &gt;, &lt;=, &gt;=, instanceof" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="546" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p11" value="parseShift()  —  &lt;&lt;, &gt;&gt;, &gt;&gt;&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="600" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p12" value="parseAdditive()  —  +, -" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="654" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p13" value="parseMultiplicative()  —  *, /, %" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="708" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p14" value="parseUnary()  —  !, ~, +, -, ++, --, (Tipo) cast" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="762" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p15" value="parsePostfix()  —  [ ], ., ( ), ++, --" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="816" width="440" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p16" value="parsePrimary()  —  literais, identificador, this, super, ( expr ), new" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="870" width="440" height="42" as="geometry" />
        </mxCell>

        <mxCell id="pe1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry" /></mxCell>
