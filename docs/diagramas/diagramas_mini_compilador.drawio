  <diagram id="arvore-escopos" name="4. Árvore de escopos (Tabela de Símbolos)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t4" value="Árvore de escopos da Tabela de Símbolos (exemplo: teste123.txt)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="360" y="0" width="700" height="30" as="geometry" />
        </mxCell>

        <mxCell id="global" value="global" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="760" y="50" width="200" height="46" as="geometry" />
        </mxCell>

        <mxCell id="classe" value="TesteCompleto (classe)&#10;campos: NOME, contador, valor, nome" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="140" width="320" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ctor" value="TesteCompleto (construtor)&#10;parâmetros: valor:int, nome:String" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="200" height="56" as="geometry" />
        </mxCell>
        <mxCell id="getValor" value="getValor (método)&#10;sem parâmetros" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="250" width="200" height="56" as="geometry" />
        </mxCell>
        <mxCell id="setValor" value="setValor (método)&#10;parâmetro: valor:int" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="250" width="200" height="56" as="geometry" />
        </mxCell>
        <mxCell id="fatorial" value="calcularFatorial (método)&#10;parâmetro: n:int" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="250" width="200" height="56" as="geometry" />
        </mxCell>
        <mxCell id="arr" value="processarArray (método)&#10;parâmetro: arr:int[]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="250" width="200" height="56" as="geometry" />
        </mxCell>
        <mxCell id="main" value="main (método static)&#10;parâmetro: args:String[]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1140" y="250" width="200" height="56" as="geometry" />
        </mxCell>

        <mxCell id="blocofor" value="bloco do for&#10;variável local: i:int" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="360" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="blocotry" value="bloco try&#10;parâmetro catch: e:ArithmeticException" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1140" y="360" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="legenda" value="lookup(nome): procura no escopo atual e sobe recursivamente pelos escopos pais, até ao escopo global (assim uma variável de instância é visível dentro de qualquer método da classe).&#10;lookupCurrentScope(nome): procura apenas no escopo indicado, sem subir aos escopos pais (usado, por exemplo, para validar objeto.campo de outra classe)." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;size=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="1320" height="80" as="geometry" />
        </mxCell>

        <mxCell id="se1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="global" target="classe"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="classe" target="ctor"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="classe" target="getValor"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="classe" target="setValor"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="classe" target="fatorial"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="classe" target="arr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="classe" target="main"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="arr" target="blocofor"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="main" target="blocotry"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="recuperacao-erros" name="5. Recuperação de erros (modo pânico)">
    <mxGraphModel dx="1000" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t5" value="Recuperação de erros sintáticos em modo pânico" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="280" y="0" width="540" height="30" as="geometry" />
        </mxCell>

        <mxCell id="start" value="Parser reconhece uma construção&#10;(declaração de topo / membro de classe / instrução)" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="40" width="320" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dec1" value="Ocorreu um erro?&#10;(token inesperado / ParseError lançado)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="140" width="280" height="90" as="geometry" />
        </mxCell>

        <mxCell id="continua" value="Continua o parsing normalmente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="740" y="160" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="throw" value="Lança ParseError&#10;(try / catch no ponto de recuperação apropriado)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="270" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="dec2" value="Em que nível da gramática&#10;ocorreu o erro?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="350" width="280" height="90" as="geometry" />
        </mxCell>

        <mxCell id="top" value="synchronizeTopLevel()&#10;avança tokens até ';' ou '}'&#10;(nível: package / import / tipo de topo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="member" value="synchronizeClassMember()&#10;avança até ';' ou '}'&#10;insere ErrorMember&#10;(nível: campo / método / construtor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="490" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="stmt" value="synchronizeStatement()&#10;avança até ';' ou '}'&#10;insere ErrorStatement&#10;(nível: instrução dentro de um bloco)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="740" y="490" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="converge" value="A AST passa a conter um nó de erro no lugar da construção falhada; a análise continua sobre o resto do ficheiro" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="610" width="420" height="60" as="geometry" />
        </mxCell>

        <mxCell id="end" value="Análise Semântica corre sobre a AST&#10;(parcialmente recuperada, se necessário)" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="710" width="420" height="60" as="geometry" />
        </mxCell>

        <mxCell id="fe1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="start" target="dec1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe2" value="não" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;fontSize=11;" edge="1" parent="1" source="dec1" target="continua"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe3" value="volta a processar a construção seguinte" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;fontSize=10;exitX=1;exitY=0.5;entryX=1;entryY=0;" edge="1" parent="1" source="continua" target="start"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1040" y="185"/><mxPoint x="1040" y="70"/></Array></mxGeometry></mxCell>
        <mxCell id="fe4" value="sim" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;fontSize=11;" edge="1" parent="1" source="dec1" target="throw"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="throw" target="dec2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe6" value="nível de topo" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;fontSize=11;" edge="1" parent="1" source="dec2" target="top"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe7" value="membro de classe" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;fontSize=11;" edge="1" parent="1" source="dec2" target="member"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe8" value="instrução" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;fontSize=11;" edge="1" parent="1" source="dec2" target="stmt"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="top" target="converge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="member" target="converge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="stmt" target="converge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fe12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="converge" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

